# Flask
SECRET_KEY=change-me-to-a-long-random-string
# 是否开启调试器：生产务必 false；本地开发设 true
FLASK_DEBUG=false
# 开发服务器监听端口，默认 5012
PORT=5012

# MySQL
DATABASE_URL=mysql+pymysql://user:password@host:3306/dnaisland

# SMTP (飞书 Lark Suite, STARTTLS 587)
MAIL_SERVER=smtp.larksuite.com
MAIL_PORT=587
MAIL_USE_TLS=true
# 飞书 SMTP 用户名 = 发件邮箱完整地址
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

